   "source": [
    "import numpy as np\n",
    "from matplotlib.pyplot import plot as plt\n",
    "\n",
    "\n",
    "N = 1000000\n",
    "\n",
    "N_inside = 0 \n",
    "\n",
    "for i in range(0, N):\n",
    "    x= np.random.ranf(1)\n",
    "    y = np.random.ranf(1)\n",
    "    r  = x**2 + y**2 \n",
    "    if r <= 1:\n",
    "        N_inside+=1\n",
    "\n",
    "pi = N_inside * 4 / N\n",
    "\n",
    "print(f\"pi={pi}\")"
   ]
